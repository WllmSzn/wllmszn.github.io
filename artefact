<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Artefact — Case study · William Suzan</title>
<meta name="description" content="Case study : Artefact, un SIEM cybersécurité conçu pour rendre l'analyse de menaces accessible aux équipes non-expertes.">
<meta name="theme-color" content="#08090C">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">

<style>
  :root {
    --bg: #08090C;
    --bg-2: #0E1015;
    --surface: rgba(255, 255, 255, 0.025);
    --surface-2: rgba(255, 255, 255, 0.04);
    --ink: #ECEEF2;
    --ink-2: #A8ADB8;
    --ink-3: #5C6270;
    --line: rgba(255, 255, 255, 0.06);
    --line-2: rgba(255, 255, 255, 0.1);
    --accent: #E8835A;
    --accent-2: #B9C7FF;
    --accent-3: #7BD9C4;
    --serif: 'Instrument Serif', Georgia, serif;
    --sans: 'Inter', -apple-system, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--sans);
    color: var(--ink);
    background: var(--bg);
    line-height: 1.6;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }

  /* === HALOS === */
  .halos { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .halo { position: absolute; border-radius: 50%; filter: blur(160px); will-change: transform; }
  .halo-1 { width: 600px; height: 600px; background: #4A5FC1; top: -200px; right: -150px; opacity: 0.1; animation: drift1 45s ease-in-out infinite; }
  .halo-2 { width: 700px; height: 700px; background: #E8835A; top: 50%; left: -250px; opacity: 0.08; animation: drift2 52s ease-in-out infinite; }
  @keyframes drift1 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-50px,80px) scale(1.1);} }
  @keyframes drift2 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(80px,-50px) scale(0.95);} }
  body::after {
    content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 1;
    opacity: 0.03; mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  ::selection { background: var(--accent); color: var(--bg); }

  /* === NAV (simplifiée, juste retour) === */
  .nav {
    position: fixed;
    top: 16px; left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    padding: 10px 14px 10px 14px;
    display: flex;
    align-items: center;
    gap: 18px;
    background: rgba(8, 9, 12, 0.7);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 0.5px solid var(--line-2);
    border-radius: 999px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.04);
  }
  .nav-back {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-2);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    border-radius: 999px;
    transition: color 0.18s, background 0.18s;
  }
  .nav-back:hover { color: var(--ink); background: var(--surface-2); }
  .nav-divider { width: 0.5px; height: 14px; background: var(--line-2); }
  .nav-current {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }
  .nav-right { display: flex; align-items: center; gap: 4px; margin-left: auto; }
  .nav-icon-link {
    width: 30px; height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--ink-2);
    transition: background 0.18s, color 0.18s;
    text-decoration: none;
  }
  .nav-icon-link:hover { background: var(--surface-2); color: var(--ink); }
  .nav-icon-link svg { width: 15px; height: 15px; }

  /* === WRAPPER === */
  .wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
    position: relative;
    z-index: 2;
  }
  .narrow {
    max-width: 760px;
    margin: 0 auto;
  }

  /* === HERO === */
  .case-hero {
    padding: 160px 0 80px;
  }
  .case-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 40px;
  }
  .case-eyebrow .pill {
    padding: 4px 10px;
    background: rgba(123,217,196,0.1);
    color: var(--accent-3);
    border: 0.5px solid rgba(123,217,196,0.3);
    border-radius: 999px;
    font-size: 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .case-eyebrow .pill::before {
    content: '';
    width: 5px; height: 5px;
    background: var(--accent-3);
    border-radius: 50%;
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1);} 50%{opacity:0.5;transform:scale(0.85);} }

  .case-title {
    font-family: var(--serif);
    font-size: clamp(56px, 9vw, 152px);
    line-height: 0.9;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin-bottom: 32px;
  }
  .case-title .it { font-style: italic; color: var(--ink-2); }
  .case-title .grad {
    background: linear-gradient(135deg, #E8835A 0%, #B9C7FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .case-subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 28px);
    line-height: 1.35;
    color: var(--ink-2);
    max-width: 720px;
    margin-bottom: 80px;
  }

  /* === META TABLE === */
  .case-meta {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 0.5px solid var(--line);
    border-bottom: 0.5px solid var(--line);
    margin-bottom: 100px;
  }
  .meta-cell {
    padding: 28px 0;
    border-right: 0.5px solid var(--line);
  }
  .meta-cell:last-child { border-right: 0; }
  .meta-cell:not(:first-child) { padding-left: 32px; }
  .meta-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
    display: block;
  }
  .meta-value {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
  }

  /* === HERO IMAGE === */
  .case-hero-image {
    aspect-ratio: 16/9;
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 0.5px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 120px;
    position: relative;
  }
  .case-hero-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .case-hero-image .placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 20% 30%, rgba(232,131,90,0.15), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(74,95,193,0.22), transparent 50%),
      linear-gradient(135deg, #0C447C 0%, #042C53 100%);
    position: relative;
  }
  .placeholder-tag {
    position: absolute;
    top: 24px; left: 24px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-3);
    padding: 5px 11px;
    border: 0.5px solid var(--line-2);
    border-radius: 999px;
    background: rgba(8,9,12,0.4);
    backdrop-filter: blur(10px);
  }
  .placeholder-inner {
    width: 70%; max-width: 700px;
  }
  .placeholder-inner svg { width: 100%; height: auto; display: block; }

  /* === CHAPTER === */
  .chapter {
    padding: 80px 0;
  }
  .chapter-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 32px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .chapter-num::before {
    content: '';
    width: 28px; height: 0.5px;
    background: var(--line-2);
  }
  .chapter-title {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 400;
    margin-bottom: 40px;
  }
  .chapter-title .it { font-style: italic; color: var(--ink-2); }

  .prose {
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink-2);
  }
  .prose p { margin-bottom: 24px; }
  .prose p:last-child { margin-bottom: 0; }
  .prose strong { color: var(--ink); font-weight: 500; }
  .prose em { color: var(--ink); font-style: italic; }

  .quote {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.35;
    color: var(--ink);
    padding: 40px 0 40px 32px;
    border-left: 1px solid var(--accent);
    margin: 40px 0;
    max-width: 720px;
  }
  .quote-attr {
    margin-top: 20px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-style: normal;
  }

  /* === IMAGE BLOCKS === */
  .image-block {
    margin: 60px 0;
  }
  .image-block.wide {
    margin-left: calc(-1 * ((100vw - 760px) / 2 - 40px));
    margin-right: calc(-1 * ((100vw - 760px) / 2 - 40px));
    max-width: none;
  }
  .image-frame {
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    border: 0.5px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 16/10;
    position: relative;
  }
  .image-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .image-frame .placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(circle at 30% 50%, rgba(232,131,90,0.1), transparent 50%),
      linear-gradient(135deg, #0C2440 0%, #051628 100%);
    position: relative;
  }
  .image-caption {
    margin-top: 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-3);
    text-align: left;
  }

  .image-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 60px 0;
  }
  .image-pair .image-frame { aspect-ratio: 4/3; }

  /* === KPI === */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 60px 0;
    padding: 40px 0;
    border-top: 0.5px solid var(--line);
    border-bottom: 0.5px solid var(--line);
  }
  .kpi-cell {
    padding: 0 24px;
    border-right: 0.5px solid var(--line);
  }
  .kpi-cell:last-child { border-right: 0; }
  .kpi-cell:first-child { padding-left: 0; }
  .kpi-val {
    font-family: var(--serif);
    font-size: clamp(40px, 4vw, 56px);
    line-height: 1;
    margin-bottom: 10px;
    letter-spacing: -0.02em;
    font-style: italic;
    background: linear-gradient(135deg, #E8835A 0%, #B9C7FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .kpi-val .plus { font-size: 0.6em; color: var(--ink-3); -webkit-text-fill-color: var(--ink-3); }
  .kpi-lbl {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    line-height: 1.4;
  }

  /* === PRINCIPLES === */
  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 0.5px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    margin: 60px 0;
  }
  .principle {
    background: var(--bg-2);
    padding: 32px 28px;
  }
  .principle-num {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-3);
    margin-bottom: 16px;
    letter-spacing: 0.08em;
  }
  .principle-title {
    font-family: var(--serif);
    font-size: 22px;
    line-height: 1.2;
    margin-bottom: 12px;
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .principle-title .it { font-style: italic; color: var(--ink-2); }
  .principle-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
  }

  /* === NEXT === */
  .next {
    padding: 120px 0 100px;
    border-top: 0.5px solid var(--line);
    text-align: left;
  }
  .next-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 24px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .next-label::before { content: ''; width: 28px; height: 0.5px; background: var(--line-2); }
  .next-title {
    font-family: var(--serif);
    font-size: clamp(48px, 8vw, 144px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin-bottom: 48px;
  }
  .next-title .grad {
    background: linear-gradient(135deg, #E8835A 0%, #B9C7FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }
  .next-row { display: flex; gap: 16px; flex-wrap: wrap; }
  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 26px;
    background: var(--ink);
    color: var(--bg);
    text-decoration: none;
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 500;
    border-radius: 999px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(236,238,242,0.15); }
  .cta-btn.ghost {
    background: var(--surface);
    color: var(--ink);
    border: 0.5px solid var(--line-2);
    backdrop-filter: blur(10px);
  }
  .cta-btn.ghost:hover { background: var(--surface-2); }

  /* === FOOTER === */
  .footer {
    border-top: 0.5px solid var(--line);
    padding: 32px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer a { color: var(--ink-2); text-decoration: none; }
  .footer a:hover { color: var(--ink); }

  /* === RESPONSIVE === */
  @media (max-width: 980px) {
    .wrap { padding: 0 20px; }
    .narrow { padding: 0 20px; }
    .nav { left: 12px; right: 12px; transform: none; padding: 8px 12px; gap: 10px; }
    .case-hero { padding: 120px 0 60px; }
    .case-meta { grid-template-columns: 1fr 1fr; }
    .meta-cell { padding-left: 0 !important; padding-right: 16px; border-right: 0; border-bottom: 0.5px solid var(--line); }
    .meta-cell:nth-child(2n) { padding-left: 16px !important; padding-right: 0; }
    .meta-cell:nth-last-child(-n+2) { border-bottom: 0; }
    .case-hero-image { margin-bottom: 60px; }
    .image-block.wide { margin-left: 0; margin-right: 0; }
    .kpi-grid { grid-template-columns: 1fr 1fr; gap: 32px 0; padding: 32px 0; }
    .kpi-cell { padding: 0 16px 0 0; border-right: 0.5px solid var(--line); }
    .kpi-cell:nth-child(2n) { padding: 0 0 0 16px; border-right: 0; }
    .principles { grid-template-columns: 1fr; }
    .image-pair { grid-template-columns: 1fr; }
    .chapter { padding: 50px 0; }
    .quote { padding: 28px 0 28px 20px; }
  }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .case-eyebrow, .case-title, .case-subtitle { animation: fadeUp 0.8s ease backwards; }
  .case-eyebrow { animation-delay: 0.05s; }
  .case-title { animation-delay: 0.15s; }
  .case-subtitle { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
    .halo { animation: none !important; }
  }
</style>
</head>

