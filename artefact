<!-- HERO -->
<section class="wrap case-hero">
  <div class="case-eyebrow">
    <span data-fr="Case study · 01" data-en="Case study · 01">Case study · 01</span>
    <span class="pill" data-fr="Projet en cours" data-en="Ongoing">Projet en cours</span>
  </div>

  <h1 class="case-title" aria-label="Artefact">
    <span>Artefact</span><span style="color: var(--accent);">.</span><br>
    <span class="it" data-fr="Rendre la" data-en="Making">Rendre la</span><br>
    <span class="grad" data-fr="cyber lisible" data-en="cyber legible">cyber lisible</span>
  </h1>

  <p class="case-subtitle"
     data-fr="Un SIEM cybersécurité conçu pour des équipes qui ne sont pas expertes. Un produit où les décisions ne se reprennent pas."
     data-en="A cybersecurity SIEM designed for teams who aren't experts. A product where decisions can't be undone.">
     Un SIEM cybersécurité conçu pour des équipes qui ne sont pas expertes. Un produit où les décisions ne se reprennent pas.
  </p>

  <div class="case-meta">
    <div class="meta-cell">
      <span class="meta-label" data-fr="Rôle" data-en="Role">Rôle</span>
      <p class="meta-value">Lead UX/UI<br>&amp; Product Owner</p>
    </div>
    <div class="meta-cell">
      <span class="meta-label" data-fr="Période" data-en="Timeline">Période</span>
      <p class="meta-value">2023 — <span data-fr="présent" data-en="present">présent</span></p>
    </div>
    <div class="meta-cell">
      <span class="meta-label" data-fr="Contexte" data-en="Context">Contexte</span>
      <p class="meta-value">SaaS B2B<br><span data-fr="Cybersécurité" data-en="Cybersecurity">Cybersécurité</span></p>
    </div>
    <div class="meta-cell">
      <span class="meta-label" data-fr="Équipe" data-en="Team">Équipe</span>
      <p class="meta-value" data-fr="Dev, ingénieurs sécurité, métiers" data-en="Dev, security engineers, business">Dev, ingénieurs sécurité, métiers</p>
    </div>
  </div>

  <!-- Image hero. Pour remplacer : retire la div .placeholder et mets <img src="assets/artefact-hero.png" alt="..."> à la place -->
